# The Anthropic key lives ONLY here, server-side. Never ships to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Single model config (constraint #5). One line to upgrade.
J1M_MODEL=claude-sonnet-4-6

# Circuit breaker + throttle (constraint #6).
J1M_DAILY_CAP_USD=10
J1M_RATE_PER_MIN=60

# Optional overrides.
# PORT=8787
# J1M_DB_PATH=./data/proxy.sqlite
